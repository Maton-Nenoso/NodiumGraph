<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ng="clr-namespace:NodiumGraph.Controls"
        xmlns:m="clr-namespace:NodiumGraph.Model">

    <Design.PreviewWith>
        <ng:NodiumGraphCanvas Width="400" Height="300" />
    </Design.PreviewWith>

    <!-- Default NodiumGraphCanvas control theme -->
    <Style Selector="ng|NodiumGraphCanvas">
        <Setter Property="Background" Value="#FF1E1E2E" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                    <Panel />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

</Styles>
