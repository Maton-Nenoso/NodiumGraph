<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ng="clr-namespace:NodiumGraph.Controls;assembly=NodiumGraph"
        xmlns:model="clr-namespace:NodiumGraph.Model;assembly=NodiumGraph"
        xmlns:local="clr-namespace:NodiumGraph.Sample"
        x:Class="NodiumGraph.Sample.MainWindow"
        Title="NodiumGraph Sample" Width="1280" Height="800">

    <Window.Styles>
        <!-- Minimal collapse toggle style -->
        <Style Selector="ToggleButton.collapseToggle">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,1" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinHeight" Value="14" />
        </Style>
        <Style Selector="ToggleButton.collapseToggle:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#10000000" />
        </Style>
        <Style Selector="ToggleButton.collapseToggle:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Window.Styles>

    <Window.DataTemplates>

        <!-- InputSourceNode: green header, CSV format info -->
        <DataTemplate DataType="local:InputSourceNode" x:DataType="local:InputSourceNode">
            <Border CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource NodiumGraphNodeBorderBrush}"
                    Background="{DynamicResource NodiumGraphNodeBodyBrush}"
                    BoxShadow="0 1 3 0 #1A000000, 0 1 2 -1 #1A000000"
                    MinWidth="150">
                <StackPanel>
                    <Border CornerRadius="8,8,0,0"
                            Background="#10B981"
                            Padding="10,6"
                            IsVisible="{Binding ShowHeader}">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="12" />
                    </Border>
                    <Border Padding="10,8"
                            IsVisible="{Binding !IsCollapsed}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Reads data from external source"
                                       Foreground="#64748B"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="Format:" Foreground="#94A3B8" FontSize="11" />
                                <TextBlock Text="CSV" Foreground="#334155" FontSize="11" FontWeight="SemiBold" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <ToggleButton Classes="collapseToggle"
                                  IsChecked="{Binding IsCollapsed}"
                                  IsVisible="{Binding IsCollapsible}">
                        <Panel>
                            <TextBlock Text="&#x25B2;" IsVisible="{Binding !IsCollapsed}" HorizontalAlignment="Center" FontSize="8" Foreground="#94A3B8" />
                            <TextBlock Text="&#x25BC;" IsVisible="{Binding IsCollapsed}" HorizontalAlignment="Center" FontSize="8" Foreground="#94A3B8" />
                        </Panel>
                    </ToggleButton>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- TransformNode: blue-to-indigo gradient header -->
        <DataTemplate DataType="local:TransformNode" x:DataType="local:TransformNode">
            <Border CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource NodiumGraphNodeBorderBrush}"
                    Background="{DynamicResource NodiumGraphNodeBodyBrush}"
                    BoxShadow="0 1 3 0 #1A000000, 0 1 2 -1 #1A000000"
                    MinWidth="150">
                <StackPanel>
                    <Border CornerRadius="8,8,0,0"
                            Padding="10,6"
                            IsVisible="{Binding ShowHeader}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                <GradientStop Color="#6366F1" Offset="0" />
                                <GradientStop Color="#8B5CF6" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="{Binding Title}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="12" />
                    </Border>
                    <Border Padding="10,8"
                            IsVisible="{Binding !IsCollapsed}">
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="Operation:" Foreground="#94A3B8" FontSize="11" />
                                <TextBlock Text="Map" Foreground="#334155" FontSize="11" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="Parallel:" Foreground="#94A3B8" FontSize="11" />
                                <TextBlock Text="true" Foreground="#334155" FontSize="11" FontWeight="SemiBold" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <ToggleButton Classes="collapseToggle"
                                  IsChecked="{Binding IsCollapsed}"
                                  IsVisible="{Binding IsCollapsible}">
                        <Panel>
                            <TextBlock Text="&#x25B2;" IsVisible="{Binding !IsCollapsed}" HorizontalAlignment="Center" FontSize="8" Foreground="#94A3B8" />
                            <TextBlock Text="&#x25BC;" IsVisible="{Binding IsCollapsed}" HorizontalAlignment="Center" FontSize="8" Foreground="#94A3B8" />
                        </Panel>
                    </ToggleButton>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- FilterNode: amber header, slider -->
        <DataTemplate DataType="local:FilterNode" x:DataType="local:FilterNode">
            <Border CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource NodiumGraphNodeBorderBrush}"
                    Background="{DynamicResource NodiumGraphNodeBodyBrush}"
                    BoxShadow="0 1 3 0 #1A000000, 0 1 2 -1 #1A000000"
                    MinWidth="150">
                <StackPanel>
                    <Border CornerRadius="8,8,0,0"
                            Background="#F59E0B"
                            Padding="10,6"
                            IsVisible="{Binding ShowHeader}">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="12" />
                    </Border>
                    <Border Padding="10,8"
                            IsVisible="{Binding !IsCollapsed}">
                        <StackPanel Spacing="3">
                            <TextBlock Text="Threshold" Foreground="#94A3B8" FontSize="11" />
                            <Slider x:Name="FilterSlider"
                                    Minimum="0" Maximum="1"
                                    Value="0.5"
                                    SmallChange="0.1"
                                    Width="120" />
                            <TextBlock Text="{Binding #FilterSlider.Value, StringFormat='{}{0:F2}'}"
                                       Foreground="#334155"
                                       FontSize="11"
                                       HorizontalAlignment="Right" />
                        </StackPanel>
                    </Border>
                    <ToggleButton Classes="collapseToggle"
                                  IsChecked="{Binding IsCollapsed}"
                                  IsVisible="{Binding IsCollapsible}">
                        <Panel>
                            <TextBlock Text="&#x25B2;" IsVisible="{Binding !IsCollapsed}" HorizontalAlignment="Center" FontSize="8" Foreground="#94A3B8" />
                            <TextBlock Text="&#x25BC;" IsVisible="{Binding IsCollapsed}" HorizontalAlignment="Center" FontSize="8" Foreground="#94A3B8" />
                        </Panel>
                    </ToggleButton>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- MergeNode: optional header, violet body, centered text -->
        <DataTemplate DataType="local:MergeNode" x:DataType="local:MergeNode">
            <Border CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="#C4B5FD"
                    Background="#8B5CF6"
                    BoxShadow="0 1 3 0 #1A000000, 0 1 2 -1 #1A000000"
                    MinWidth="150">
                <StackPanel>
                    <Border CornerRadius="8,8,0,0"
                            Background="#7C3AED"
                            Padding="10,6"
                            IsVisible="{Binding ShowHeader}">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="12" />
                    </Border>
                    <Border Padding="10,8"
                            MinHeight="50"
                            IsVisible="{Binding !IsCollapsed}">
                        <TextBlock Text="Combines multiple inputs"
                                   Foreground="#F5F3FF"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <ToggleButton Classes="collapseToggle"
                                  IsChecked="{Binding IsCollapsed}"
                                  IsVisible="{Binding IsCollapsible}">
                        <Panel>
                            <TextBlock Text="&#x25B2;" IsVisible="{Binding !IsCollapsed}" HorizontalAlignment="Center" FontSize="8" Foreground="#C4B5FD" />
                            <TextBlock Text="&#x25BC;" IsVisible="{Binding IsCollapsed}" HorizontalAlignment="Center" FontSize="8" Foreground="#C4B5FD" />
                        </Panel>
                    </ToggleButton>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- OutputSinkNode: rose header, destination + checkbox -->
        <DataTemplate DataType="local:OutputSinkNode" x:DataType="local:OutputSinkNode">
            <Border CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource NodiumGraphNodeBorderBrush}"
                    Background="{DynamicResource NodiumGraphNodeBodyBrush}"
                    BoxShadow="0 1 3 0 #1A000000, 0 1 2 -1 #1A000000"
                    MinWidth="150">
                <StackPanel>
                    <Border CornerRadius="8,8,0,0"
                            Background="#EF4444"
                            Padding="10,6"
                            IsVisible="{Binding ShowHeader}">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="12" />
                    </Border>
                    <Border Padding="10,8"
                            IsVisible="{Binding !IsCollapsed}">
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="Destination:" Foreground="#94A3B8" FontSize="11" />
                                <TextBlock Text="stdout" Foreground="#334155" FontSize="11" FontWeight="SemiBold" />
                            </StackPanel>
                            <CheckBox Content="Append mode"
                                      FontSize="11"
                                      Foreground="#64748B"
                                      IsChecked="False" />
                        </StackPanel>
                    </Border>
                    <ToggleButton Classes="collapseToggle"
                                  IsChecked="{Binding IsCollapsed}"
                                  IsVisible="{Binding IsCollapsible}">
                        <Panel>
                            <TextBlock Text="&#x25B2;" IsVisible="{Binding !IsCollapsed}" HorizontalAlignment="Center" FontSize="8" Foreground="#94A3B8" />
                            <TextBlock Text="&#x25BC;" IsVisible="{Binding IsCollapsed}" HorizontalAlignment="Center" FontSize="8" Foreground="#94A3B8" />
                        </Panel>
                    </ToggleButton>
                </StackPanel>
            </Border>
        </DataTemplate>

    </Window.DataTemplates>

    <Grid ColumnDefinitions="220,*">

        <!-- Sidebar -->
        <Border Grid.Column="0"
                BorderBrush="#FFD0D0D0"
                BorderThickness="0,0,1,0"
                Padding="12">
            <ScrollViewer>
                <StackPanel Spacing="16">

                    <TextBlock Text="Grid"
                               FontSize="14" FontWeight="SemiBold" />

                    <StackPanel Spacing="4">
                        <ToggleSwitch IsChecked="{Binding #Canvas.ShowGrid}"
                                      Content="Show Grid"
                                      OnContent="On" OffContent="Off" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Style" FontSize="12" />
                        <ComboBox x:Name="GridStyleCombo" SelectedIndex="1">
                            <ComboBoxItem Content="None" Tag="{x:Static ng:GridStyle.None}" />
                            <ComboBoxItem Content="Dots" Tag="{x:Static ng:GridStyle.Dots}" />
                            <ComboBoxItem Content="Lines" Tag="{x:Static ng:GridStyle.Lines}" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding #GridSizeSlider.Value, StringFormat='Grid Size: {0:F0}'}"
                                   FontSize="12" />
                        <Slider x:Name="GridSizeSlider"
                                Minimum="5" Maximum="100"
                                Value="{Binding #Canvas.GridSize}"
                                TickFrequency="5"
                                IsSnapToTickEnabled="True" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <ToggleSwitch IsChecked="{Binding #Canvas.SnapToGrid}"
                                      Content="Snap to Grid"
                                      OnContent="On" OffContent="Off" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding #MajorIntervalSlider.Value, StringFormat='Major Interval: {0:F0}'}"
                                   FontSize="12" />
                        <Slider x:Name="MajorIntervalSlider"
                                Minimum="2" Maximum="20"
                                Value="{Binding #Canvas.MajorGridInterval}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <ToggleSwitch IsChecked="{Binding #Canvas.ShowOriginAxes}"
                                      Content="Origin Axes"
                                      OnContent="On" OffContent="Off" />
                    </StackPanel>

                    <!-- Snap section -->
                    <TextBlock Text="Snap"
                               FontSize="14" FontWeight="SemiBold" />

                    <StackPanel Spacing="4">
                        <ToggleSwitch IsChecked="{Binding #Canvas.ShowSnapGhost}"
                                      Content="Snap Ghost"
                                      OnContent="On" OffContent="Off" />
                    </StackPanel>

                    <!-- Node Features section -->
                    <TextBlock Text="Node Features"
                               FontSize="14" FontWeight="SemiBold" />

                    <StackPanel Spacing="4">
                        <ToggleSwitch x:Name="CollapseTransformToggle"
                                      Content="Transform Collapsible"
                                      IsChecked="True"
                                      OnContent="On" OffContent="Off" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <ToggleSwitch x:Name="ShowMergeHeaderToggle"
                                      Content="Show Merge Header"
                                      OnContent="On" OffContent="Off" />
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Canvas -->
        <ng:NodiumGraphCanvas x:Name="Canvas"
                              Grid.Column="1"
                              Background="#FFF1F5F9"
                              ShowGrid="True"
                              SnapToGrid="False"
                              ShowMinimap="True" />
    </Grid>
</Window>
