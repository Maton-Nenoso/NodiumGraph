<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ng="clr-namespace:NodiumGraph.Controls;assembly=NodiumGraph"
        xmlns:model="clr-namespace:NodiumGraph.Model;assembly=NodiumGraph"
        xmlns:local="clr-namespace:NodiumGraph.Sample"
        x:Class="NodiumGraph.Sample.MainWindow"
        Title="NodiumGraph Sample" Width="1280" Height="800">

    <Window.Resources>
        <local:BooleanInvertConverter x:Key="InvertBool" />
    </Window.Resources>

    <Window.DataTemplates>

        <!-- InputSourceNode: green header, CSV format info -->
        <DataTemplate DataType="local:InputSourceNode" x:DataType="local:InputSourceNode">
            <Border CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource NodiumNodeBorderBrush}"
                    Background="{DynamicResource NodiumNodeBodyBrush}"
                    MinWidth="130">
                <StackPanel>
                    <!-- Header -->
                    <Border CornerRadius="6,6,0,0"
                            Background="#4CAF50"
                            Padding="8,4"
                            IsVisible="{Binding ShowHeader}">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="12" />
                    </Border>
                    <!-- Body -->
                    <Border Padding="8,6"
                            IsVisible="{Binding IsCollapsed, Converter={StaticResource InvertBool}}">
                        <StackPanel Spacing="3">
                            <TextBlock Text="Reads data from external source"
                                       Foreground="#A0A0A0"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="Format:" Foreground="#A0A0A0" FontSize="11" />
                                <TextBlock Text="CSV" Foreground="#D2D2D2" FontSize="11" FontWeight="SemiBold" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- TransformNode: blue-to-purple gradient header, dark blue border -->
        <DataTemplate DataType="local:TransformNode" x:DataType="local:TransformNode">
            <Border CornerRadius="6"
                    BorderThickness="2"
                    BorderBrush="#2850A0"
                    Background="{DynamicResource NodiumNodeBodyBrush}"
                    MinWidth="130">
                <StackPanel>
                    <!-- Header -->
                    <Border CornerRadius="6,6,0,0"
                            Padding="8,4"
                            IsVisible="{Binding ShowHeader}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                <GradientStop Color="#4285F4" Offset="0" />
                                <GradientStop Color="#9C27B0" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="{Binding Title}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="12" />
                    </Border>
                    <!-- Body -->
                    <Border Padding="8,6"
                            IsVisible="{Binding IsCollapsed, Converter={StaticResource InvertBool}}">
                        <StackPanel Spacing="3">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="Operation:" Foreground="#A0A0A0" FontSize="11" />
                                <TextBlock Text="Map" Foreground="#D2D2D2" FontSize="11" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="Parallel:" Foreground="#A0A0A0" FontSize="11" />
                                <TextBlock Text="true" Foreground="#D2D2D2" FontSize="11" FontWeight="SemiBold" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- FilterNode: orange header, opacity 0.85, slider -->
        <DataTemplate DataType="local:FilterNode" x:DataType="local:FilterNode">
            <Border CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource NodiumNodeBorderBrush}"
                    Background="{DynamicResource NodiumNodeBodyBrush}"
                    MinWidth="130"
                    Opacity="0.85">
                <StackPanel>
                    <!-- Header -->
                    <Border CornerRadius="6,6,0,0"
                            Background="#FF9800"
                            Padding="8,4"
                            IsVisible="{Binding ShowHeader}">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="12" />
                    </Border>
                    <!-- Body -->
                    <Border Padding="8,6"
                            IsVisible="{Binding IsCollapsed, Converter={StaticResource InvertBool}}">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Threshold" Foreground="#A0A0A0" FontSize="11" />
                            <Slider x:Name="FilterSlider"
                                    Minimum="0" Maximum="1"
                                    Value="0.5"
                                    SmallChange="0.1"
                                    Width="110" />
                            <TextBlock Text="{Binding #FilterSlider.Value, StringFormat='{}{0:F2}'}"
                                       Foreground="#D2D2D2"
                                       FontSize="11"
                                       HorizontalAlignment="Right" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- MergeNode: no header, purple body, centered text -->
        <DataTemplate DataType="local:MergeNode" x:DataType="local:MergeNode">
            <Border CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource NodiumNodeBorderBrush}"
                    Background="#9C27B0"
                    MinWidth="130">
                <Border Padding="8,6"
                        MinHeight="50"
                        IsVisible="{Binding IsCollapsed, Converter={StaticResource InvertBool}}">
                    <TextBlock Text="Combines multiple inputs"
                               Foreground="#E6E6E6"
                               FontSize="11"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
            </Border>
        </DataTemplate>

        <!-- OutputSinkNode: red header, destination + checkbox -->
        <DataTemplate DataType="local:OutputSinkNode" x:DataType="local:OutputSinkNode">
            <Border CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource NodiumNodeBorderBrush}"
                    Background="{DynamicResource NodiumNodeBodyBrush}"
                    MinWidth="130">
                <StackPanel>
                    <!-- Header -->
                    <Border CornerRadius="6,6,0,0"
                            Background="#F44336"
                            Padding="8,4"
                            IsVisible="{Binding ShowHeader}">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="12" />
                    </Border>
                    <!-- Body -->
                    <Border Padding="8,6"
                            IsVisible="{Binding IsCollapsed, Converter={StaticResource InvertBool}}">
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="Destination:" Foreground="#A0A0A0" FontSize="11" />
                                <TextBlock Text="stdout" Foreground="#D2D2D2" FontSize="11" FontWeight="SemiBold" />
                            </StackPanel>
                            <CheckBox Content="Append mode"
                                      FontSize="11"
                                      Foreground="#A0A0A0"
                                      IsChecked="False" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>

    </Window.DataTemplates>

    <Grid ColumnDefinitions="220,*">

        <!-- Sidebar -->
        <Border Grid.Column="0"
                BorderBrush="#FFD0D0D0"
                BorderThickness="0,0,1,0"
                Padding="12">
            <ScrollViewer>
                <StackPanel Spacing="16">

                    <TextBlock Text="Grid"
                               FontSize="14" FontWeight="SemiBold" />

                    <StackPanel Spacing="4">
                        <ToggleSwitch IsChecked="{Binding #Canvas.ShowGrid}"
                                      Content="Show Grid"
                                      OnContent="On" OffContent="Off" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Style" FontSize="12" />
                        <ComboBox x:Name="GridStyleCombo" SelectedIndex="1">
                            <ComboBoxItem Content="None" Tag="{x:Static ng:GridStyle.None}" />
                            <ComboBoxItem Content="Dots" Tag="{x:Static ng:GridStyle.Dots}" />
                            <ComboBoxItem Content="Lines" Tag="{x:Static ng:GridStyle.Lines}" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding #GridSizeSlider.Value, StringFormat='Grid Size: {0:F0}'}"
                                   FontSize="12" />
                        <Slider x:Name="GridSizeSlider"
                                Minimum="5" Maximum="100"
                                Value="{Binding #Canvas.GridSize}"
                                TickFrequency="5"
                                IsSnapToTickEnabled="True" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <ToggleSwitch IsChecked="{Binding #Canvas.SnapToGrid}"
                                      Content="Snap to Grid"
                                      OnContent="On" OffContent="Off" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding #MajorIntervalSlider.Value, StringFormat='Major Interval: {0:F0}'}"
                                   FontSize="12" />
                        <Slider x:Name="MajorIntervalSlider"
                                Minimum="2" Maximum="20"
                                Value="{Binding #Canvas.MajorGridInterval}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <ToggleSwitch IsChecked="{Binding #Canvas.ShowOriginAxes}"
                                      Content="Origin Axes"
                                      OnContent="On" OffContent="Off" />
                    </StackPanel>

                    <!-- Snap section -->
                    <TextBlock Text="Snap"
                               FontSize="14" FontWeight="SemiBold" />

                    <StackPanel Spacing="4">
                        <ToggleSwitch IsChecked="{Binding #Canvas.ShowSnapGhost}"
                                      Content="Snap Ghost"
                                      OnContent="On" OffContent="Off" />
                    </StackPanel>

                    <!-- Node Features section -->
                    <TextBlock Text="Node Features"
                               FontSize="14" FontWeight="SemiBold" />

                    <StackPanel Spacing="4">
                        <ToggleSwitch x:Name="CollapseTransformToggle"
                                      Content="Collapse Transform"
                                      OnContent="On" OffContent="Off" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <ToggleSwitch x:Name="ShowMergeHeaderToggle"
                                      Content="Show Merge Header"
                                      OnContent="On" OffContent="Off" />
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Canvas -->
        <ng:NodiumGraphCanvas x:Name="Canvas"
                              Grid.Column="1"
                              Background="#FFF5F5F5"
                              ShowGrid="True"
                              SnapToGrid="False"
                              ShowMinimap="True" />
    </Grid>
</Window>
